rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /customers/{id} {
      allow read, write: if request.auth != null;
    }

    match /histories/{id} {
    	allow read: if request.auth != null;
    	allow write: if request.resource.data.uid == request.auth.uid;
    }

    match /items/{id} {
      allow read, write: if request.auth != null;
    }

    match /orders/{id} {
    	allow read: if request.auth != null;
      allow write;
    }

    match /stickers/{id} {
    	allow read, write: if request.auth != null;
    }

    match /storages/{id} {
    	allow read, write: if request.auth != null;
    }
  }
}
